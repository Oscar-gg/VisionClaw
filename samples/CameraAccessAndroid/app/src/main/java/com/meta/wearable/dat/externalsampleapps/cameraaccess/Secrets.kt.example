package com.meta.wearable.dat.externalsampleapps.cameraaccess

object Secrets {
    // REQUIRED: Get your key at https://aistudio.google.com/apikey
    const val geminiAPIKey = "YOUR_GEMINI_API_KEY"

    // OPTIONAL: Claude Code bridge server config (for agentic tool-calling)
    // Run server/ (npm run dev) on your Mac, then fill in your Mac's Bonjour hostname
    // (run: scutil --get LocalHostName) and the token you set via CLAUDE_CODE_TOKEN.
    // Gemini passes visual context to Claude automatically via the system prompt.
    const val claudeCodeHost = "http://YOUR_MAC_HOSTNAME.local"
    const val claudeCodePort = 18789
    const val claudeCodeToken = "YOUR_CLAUDE_CODE_TOKEN"

    // OPTIONAL: WebRTC signaling server URL (for live POV streaming)
    const val webrtcSignalingURL = "wss://YOUR_SIGNALING_SERVER"
}
